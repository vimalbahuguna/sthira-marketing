---
import Layout from '../layouts/Layout.astro';

const FORM_ENDPOINT = 'https://gzhxgoigflftharcmdqj.supabase.co/functions/v1/marketing-inquiry';
---

<Layout
  title="Join the Sthira waitlist"
  description="Sthira is in closed pilot. Join the waitlist and we'll invite you when SEBI advisor onboarding closes."
>
  <section class="mx-auto max-w-2xl px-6 py-20">
    <p class="text-sm font-medium uppercase tracking-wider text-emerald-700">Waitlist</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">Be among the first to invest the boring way.</h1>
    <p class="mt-4 text-slate-600">
      Sthira is in closed pilot until SEBI advisor onboarding closes. Tell us a little
      about how you invest today — we'll let you in when we open up.
    </p>

    <form
      id="contact-form"
      data-endpoint={FORM_ENDPOINT}
      class="mt-10 space-y-5"
      novalidate
    >
      {/* Honeypot */}
      <input
        type="text"
        name="website"
        autocomplete="off"
        tabindex="-1"
        class="absolute left-[-9999px] h-0 w-0 opacity-0"
        aria-hidden="true"
      />

      <div>
        <label for="name" class="block text-sm font-medium">Your name</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          maxlength="200"
          class="mt-1 w-full rounded-md border border-slate-200 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          maxlength="200"
          class="mt-1 w-full rounded-md border border-slate-200 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none"
        />
      </div>
      <div>
        <label for="role" class="block text-sm font-medium">How do you invest today?</label>
        <select
          id="role"
          name="role"
          class="mt-1 w-full rounded-md border border-slate-200 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none"
        >
          <option value="sip-only">SIPs only (mutual funds)</option>
          <option value="mixed">Mix of SIPs and direct stocks</option>
          <option value="active">Active trading (stocks, F&O)</option>
          <option value="advisor">Through a financial advisor</option>
          <option value="none">I don't invest yet</option>
          <option value="other">Something else</option>
        </select>
      </div>
      <div>
        <label for="message" class="block text-sm font-medium">What's frustrating about how you invest today? (optional)</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          maxlength="5000"
          class="mt-1 w-full rounded-md border border-slate-200 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none"
          placeholder="e.g., I miss SIP debits when my account is short, I rebalance once a year and feel guilty about it, I never know what my advisor changed."
        ></textarea>
      </div>
      <button
        type="submit"
        id="contact-submit"
        class="rounded-lg bg-emerald-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-emerald-600 disabled:opacity-60 disabled:cursor-not-allowed"
      >
        Join waitlist
      </button>

      <div
        id="contact-feedback"
        class="hidden rounded-md border px-4 py-3 text-sm"
        role="status"
        aria-live="polite"
      ></div>

      <p class="text-xs text-slate-500">
        We won't email you marketing without an explicit opt-in. We will email you when
        Sthira opens up.
      </p>
    </form>

    <div class="mt-12 border-t border-slate-200 pt-6 text-sm text-slate-600">
      Prefer email? Reach us at{' '}
      <a href="mailto:hello@sosservices.online" class="text-slate-900 underline">
        hello@sosservices.online
      </a>
      .
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById('contact-form');
      if (!form) return;
      const endpoint = form.dataset.endpoint;
      const submit = document.getElementById('contact-submit');
      const feedback = document.getElementById('contact-feedback');

      const showFeedback = (kind, msg) => {
        feedback.textContent = msg;
        feedback.className = `rounded-md border px-4 py-3 text-sm ${
          kind === 'ok'
            ? 'border-emerald-200 bg-emerald-50 text-emerald-700'
            : 'border-rose-200 bg-rose-50 text-rose-700'
        }`;
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submit.disabled = true;
        const originalLabel = submit.textContent;
        submit.textContent = 'Sending…';

        const data = Object.fromEntries(new FormData(form).entries());

        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          const json = await res.json().catch(() => ({}));
          if (res.ok) {
            showFeedback('ok', "You're on the list. We'll be in touch when Sthira opens up.");
            form.reset();
          } else {
            showFeedback('err', json.error || 'Something went wrong. Please email us directly.');
          }
        } catch {
          showFeedback('err', 'Network error. Please email us directly.');
        } finally {
          submit.disabled = false;
          submit.textContent = originalLabel;
        }
      });
    })();
  </script>
</Layout>
