---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const features = await getCollection('features');
  return features.map((feature) => ({
    params: { slug: feature.id },
    props: { feature },
  }));
}

const { feature } = Astro.props;
const { name, tagline, description, accent, category, bullets } = feature.data;
const { Content } = await render(feature);

const featureSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: `${name} — Sthira`,
  description,
  applicationCategory: 'FinanceApplication',
  applicationSubCategory: category,
  operatingSystem: 'Android, Web',
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  isPartOf: {
    '@type': 'SoftwareApplication',
    name: 'Sthira',
    url: 'https://sthira.sosservices.online',
  },
  provider: {
    '@type': 'Organization',
    name: 'SOS Services',
    url: 'https://sosservices.online',
  },
  featureList: bullets,
};
---

<Layout title={`${name} — Sthira`} description={description} jsonLd={featureSchema}>
  <article class="mx-auto max-w-3xl px-6 py-20">
    <div class="h-2 w-16 rounded-full" style={`background-color: ${accent}`}></div>

    <p class="mt-6 text-sm font-medium uppercase tracking-wider text-slate-500">
      Feature · {category}
    </p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight">{name}</h1>
    <p class="mt-3 text-lg text-slate-700">{tagline}</p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/contact"
        class="rounded-lg bg-emerald-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-emerald-600"
      >
        Join the waitlist
      </a>
      <a
        href="/#features"
        class="rounded-lg border border-slate-200 px-5 py-2.5 text-sm font-medium text-slate-900 hover:border-slate-300"
      >
        ← All features
      </a>
    </div>

    <section class="mt-10 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">
        At a glance
      </h2>
      <ul class="mt-3 space-y-2 text-sm text-slate-800">
        {
          bullets.map((b) => (
            <li class="flex items-start gap-2">
              <span class="text-slate-300">▸</span>
              <span>{b}</span>
            </li>
          ))
        }
      </ul>
    </section>

    <div class="prose prose-slate mt-12 max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-h2:mt-12 prose-h2:text-2xl">
      <Content />
    </div>
  </article>
</Layout>
