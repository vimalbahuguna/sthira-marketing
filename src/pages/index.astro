---
import Layout from '../layouts/Layout.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ProofBand from '../components/ProofBand.astro';
import FadeUpOnScroll from '../components/FadeUpOnScroll.astro';
import { getCollection } from 'astro:content';

const features = (await getCollection('features')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout>
  {/* Hero — dark, emerald accent */}
  <section class="relative isolate overflow-hidden bg-slate-950 text-white">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-950 via-slate-950 to-slate-900"></div>
    <div class="pointer-events-none absolute -left-32 -top-32 h-96 w-96 rounded-full bg-emerald-500/20 blur-3xl" aria-hidden="true"></div>
    <div class="pointer-events-none absolute -right-32 top-1/3 h-96 w-96 rounded-full bg-emerald-500/10 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-6xl px-6 pt-10 pb-6 sm:pt-14 sm:pb-8">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div class="text-center lg:text-left">
          <p class="text-xs font-medium uppercase tracking-[0.32em] text-emerald-400">
            By SOS Markets · Plain-English investing
          </p>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
            For investors, not traders.
          </h1>
          <p class="mt-3 text-base text-slate-300 sm:text-lg">
            Sthira runs your SIPs, watches for drift, and asks before it acts.
            The LLM explains — it never executes.
          </p>
          <div class="mt-5 flex flex-col items-center justify-center gap-3 sm:flex-row lg:justify-start">
            <a
              href="/contact"
              class="rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-950 shadow-sm transition hover:bg-emerald-400"
            >
              Join the waitlist
            </a>
            <a
              href="#features"
              class="rounded-lg border border-slate-700 px-5 py-2.5 text-sm font-semibold text-slate-100 transition hover:border-slate-500 hover:bg-slate-900"
            >
              How it works →
            </a>
          </div>
          <p class="mt-4 text-xs text-slate-500">
            Goal-based SIPs · Drift rebalancing · SEBI-aligned · No LLM trades
          </p>
        </div>
        <div class="relative mx-auto aspect-[3/5] w-full max-w-[280px] overflow-hidden rounded-2xl border border-slate-800/60 bg-slate-900/40 shadow-2xl shadow-emerald-500/10 backdrop-blur lg:max-w-none">
          <img
            src="/app-preview.svg"
            alt="Sthira mobile app — portfolio + SIP overview"
            loading="eager"
            decoding="async"
            class="h-full w-full object-contain"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Proof band — merged trust badges + outcome metrics + restraint disclaimer */}
  <ProofBand />

  {/* Features grid */}
  <section id="features" class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight">How Sthira works</h2>
        <p class="mt-2 text-slate-600">
          Eight pieces that turn "I should invest" into "I am invested, and I know why."
        </p>
      </div>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => <FeatureCard feature={feature} />)}
    </div>
  </section>

  {/* Why */}
  <section class="border-t border-slate-200 bg-slate-50">
    <div class="motion-rise mx-auto max-w-6xl px-6 py-12 sm:py-16">
      <h2 class="text-3xl font-semibold tracking-tight">Why Sthira instead of another trading app</h2>
      <dl class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <div>
          <dt class="font-medium">Investing, not trading</dt>
          <dd class="mt-2 text-sm text-slate-600">
            Sthira is built for the long game. No leverage, no F&O nudges, no
            "watchlist gone red" doom scrolling. SIPs and rebalancing — that's it.
          </dd>
        </div>
        <div>
          <dt class="font-medium">The LLM is a teacher, not a trader</dt>
          <dd class="mt-2 text-sm text-slate-600">
            Ask why your portfolio drifted. Ask what an expense ratio is. Ask how the
            rebalancing math works. The LLM answers. It does not click "buy."
          </dd>
        </div>
        <div>
          <dt class="font-medium">Pre-authorized, not surprise-charged</dt>
          <dd class="mt-2 text-sm text-slate-600">
            Every rebalance is bounded by limits you set up front. You approve the plan
            once. The plan respects it forever. No upsells, no nudges to "boost return."
          </dd>
        </div>
        <div>
          <dt class="font-medium">Your broker, not ours</dt>
          <dd class="mt-2 text-sm text-slate-600">
            Sthira connects to your existing broker account (Groww first, more coming).
            We don't custody your money. We orchestrate it.
          </dd>
        </div>
        <div>
          <dt class="font-medium">Audit trail by default</dt>
          <dd class="mt-2 text-sm text-slate-600">
            Every recommendation, every approval, every order — recorded with its
            reasoning. Your CA, your spouse, and your future self can all reconstruct
            what happened and why.
          </dd>
        </div>
        <div>
          <dt class="font-medium">Built for the layman</dt>
          <dd class="mt-2 text-sm text-slate-600">
            No "alpha." No "beta." No "max drawdown." The screens say "this is the
            goal," "this is what's happening," "this is what changed." That's it.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  {/* Pricing — pilot tiers */}
  <section class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
    <div class="motion-rise mb-10 text-center">
      <p class="text-xs font-medium uppercase tracking-[0.32em] text-emerald-700">Pricing</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight">Flat fee. No commissions.</h2>
      <p class="mx-auto mt-3 max-w-xl text-slate-600">
        Indicative pilot pricing. Final tiers publish at GA — early users lock in
        Founding Member pricing.
      </p>
    </div>

    <div class="motion-rise grid gap-6 lg:grid-cols-3">
      <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-8">
        <p class="text-xs font-medium uppercase tracking-wider text-slate-500">Free</p>
        <p class="mt-3 flex items-baseline gap-1">
          <span class="text-4xl font-bold tracking-tight">₹0</span>
          <span class="text-sm text-slate-500">forever</span>
        </p>
        <p class="mt-2 text-sm text-slate-600">Get a SIP going + see your drift. The honest starting point.</p>
        <ul class="mt-6 flex-1 space-y-2 text-sm text-slate-700">
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>1 portfolio</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Goal-based SIPs from ₹100/month</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Drift rebalancing (manual approval)</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Basic LLM explainer</span></li>
        </ul>
        <a href="/contact?tier=free" class="mt-6 rounded-lg border border-slate-200 px-4 py-2 text-center text-sm font-medium text-slate-900 hover:border-slate-300">
          Open free account
        </a>
      </div>

      <div class="relative flex flex-col rounded-2xl border-2 border-emerald-500 bg-white p-8 shadow-lg">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-3 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white">
          Most popular
        </span>
        <p class="text-xs font-medium uppercase tracking-wider text-emerald-700">Pro</p>
        <p class="mt-3 flex items-baseline gap-1">
          <span class="text-4xl font-bold tracking-tight">₹499</span>
          <span class="text-sm text-slate-500">/ month</span>
        </p>
        <p class="mt-2 text-sm text-slate-600">For investors who want the LLM to actually be useful.</p>
        <ul class="mt-6 flex-1 space-y-2 text-sm text-slate-700">
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Up to 5 portfolios</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Everything in Free</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Advanced LLM (priority model, longer context)</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Pre-authorised rebalancing (Tier 2)</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Audit-trail exports for your CA</span></li>
        </ul>
        <a href="/contact?tier=pro" class="mt-6 rounded-lg bg-emerald-600 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-emerald-700">
          Start Pro pilot
        </a>
      </div>

      <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-8">
        <p class="text-xs font-medium uppercase tracking-wider text-slate-500">Family</p>
        <p class="mt-3 flex items-baseline gap-1">
          <span class="text-4xl font-bold tracking-tight">₹1,499</span>
          <span class="text-sm text-slate-500">/ month</span>
        </p>
        <p class="mt-2 text-sm text-slate-600">One subscription for the whole household's investing.</p>
        <ul class="mt-6 flex-1 space-y-2 text-sm text-slate-700">
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Up to 10 portfolios across 4 members</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Joint household-goals view</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Consolidated audit bundles for joint ITR</span></li>
          <li class="flex gap-2"><span class="text-emerald-500">✓</span><span>Priority support</span></li>
        </ul>
        <a href="/contact?tier=family" class="mt-6 rounded-lg border border-slate-200 px-4 py-2 text-center text-sm font-medium text-slate-900 hover:border-slate-300">
          Start Family pilot
        </a>
      </div>
    </div>
    <p class="motion-rise mt-8 text-center text-xs text-slate-500">
      Zero commissions on every tier. Sthira never takes a cut of your trades — your
      broker does what it does, we orchestrate. Per-trade biometric authorisation +
      5-second SEBI disclaimer apply to all tiers.
    </p>
  </section>

  {/* From the studio rail — cross-link to parent's retail/markets engineering content */}
  <section class="border-t border-slate-200 bg-slate-50">
    <div class="motion-rise mx-auto max-w-6xl px-6 py-16">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <p class="text-sm font-medium uppercase tracking-wider text-emerald-700">From the studio</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight">How we build Sthira</h2>
        </div>
        <a
          href="https://sosservices.online/engineering/"
          class="hidden text-sm text-slate-600 hover:text-slate-900 sm:block"
          target="_blank"
          rel="noreferrer"
        >
          All engineering posts ↗
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <a
          href="https://sosservices.online/engineering/why-we-dont-let-the-llm-trade-for-you/"
          class="block rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-slate-300 hover:shadow-md"
          target="_blank"
          rel="noreferrer"
        >
          <p class="text-xs font-medium uppercase tracking-wider text-emerald-700">Retail</p>
          <h3 class="mt-2 text-lg font-semibold tracking-tight text-slate-900">
            Why we don't let the LLM trade for you
          </h3>
          <p class="mt-2 text-sm text-slate-600">
            The full argument: fiduciary duty, SEBI lines, layman audience, what
            automation actually buys you when the model isn't pulling the trigger.
          </p>
          <p class="mt-3 text-sm font-medium text-slate-900">Read on sosservices.online →</p>
        </a>
        <a
          href="https://logicnexus.sosservices.online"
          class="block rounded-2xl border border-sky-200 bg-sky-50/40 p-6 transition hover:border-sky-300 hover:shadow-md"
          target="_blank"
          rel="noreferrer"
        >
          <p class="text-xs font-medium uppercase tracking-wider text-sky-700">Sibling product</p>
          <h3 class="mt-2 text-lg font-semibold tracking-tight text-slate-900">
            Logic Nexus — operations for operators
          </h3>
          <p class="mt-2 text-sm text-slate-600">
            Multi-tenant logistics SaaS for freight, finance, compliance, and AMRO —
            wired together from day one.
          </p>
          <p class="mt-3 text-sm font-medium text-slate-900">Visit logicnexus.sosservices.online →</p>
        </a>
        <a
          href="https://aviation.sosservices.online"
          class="block rounded-2xl border border-red-200 bg-red-50/40 p-6 transition hover:border-red-300 hover:shadow-md"
          target="_blank"
          rel="noreferrer"
        >
          <p class="text-xs font-medium uppercase tracking-wider text-red-700">Sibling product</p>
          <h3 class="mt-2 text-lg font-semibold tracking-tight text-slate-900">
            Aviation AI Pro — flight data analytics
          </h3>
          <p class="mt-2 text-sm text-slate-600">
            ARINC 717 parsing, multi-vendor DLU decoding, approach scoring, DGCA-ready
            exports. Built for the safety officer.
          </p>
          <p class="mt-3 text-sm font-medium text-slate-900">Visit aviation.sosservices.online →</p>
        </a>
        <a
          href="https://amropro.sosservices.online"
          class="block rounded-2xl border border-purple-200 bg-purple-50/40 p-6 transition hover:border-purple-300 hover:shadow-md"
          target="_blank"
          rel="noreferrer"
        >
          <p class="text-xs font-medium uppercase tracking-wider text-purple-700">Sibling product</p>
          <h3 class="mt-2 text-lg font-semibold tracking-tight text-slate-900">
            AMRO Pro — aircraft maintenance
          </h3>
          <p class="mt-2 text-sm text-slate-600">
            Multi-regulator MRO software (FAA / EASA / CAAC / SACAA). Work orders, MPDs,
            parts traceability — without the SAP price tag.
          </p>
          <p class="mt-3 text-sm font-medium text-slate-900">Visit amropro.sosservices.online →</p>
        </a>
      </div>
    </div>
  </section>
  <FadeUpOnScroll />
</Layout>
