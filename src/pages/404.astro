---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found — Sthira" description="The page you were looking for doesn't exist.">
  <section class="mx-auto max-w-xl px-6 py-32 text-center">
    <p class="text-sm font-medium uppercase tracking-wider text-slate-500">404</p>
    <h1 class="mt-3 text-5xl font-semibold tracking-tight">Not here.</h1>
    <p class="mt-4 text-slate-600">
      The page you were after doesn't exist. It may have moved, or never existed.
    </p>
    <div class="mt-8 flex justify-center gap-3">
      <a href="/" class="rounded-lg bg-emerald-700 px-5 py-2.5 text-sm font-medium text-white hover:bg-emerald-600">
        Take me home
      </a>
      <a href="/#features" class="rounded-lg border border-slate-200 px-5 py-2.5 text-sm font-medium hover:border-slate-300">
        How it works
      </a>
    </div>
  </section>
</Layout>
