---
const badges = [
  { label: 'SEBI-aligned advisory', sub: 'IA-Code 2026 ready' },
  { label: '100% human approval', sub: 'Tier-2 rebalance requires sign-off' },
  { label: '5-second SEBI disclaimer', sub: 'hard-coded into every trade flow' },
  { label: '₹100 minimum SIP', sub: 'low-stakes entry for layman investors' },
];
---

<section class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-6 py-6">
    <p class="text-center text-[11px] font-medium uppercase tracking-[0.28em] text-slate-500">
      Built for layman retail investors — calmly, on the regulator's side
    </p>
    <ul role="list" class="mt-4 grid grid-cols-2 gap-4 text-center sm:grid-cols-4">
      {
        badges.map((b) => (
          <li>
            <p class="text-sm font-medium text-slate-200">{b.label}</p>
            <p class="mt-0.5 text-xs text-slate-500">{b.sub}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
