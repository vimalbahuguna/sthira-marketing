---
// Sthira outcome stats. The brand stance is restraint — these numbers prove
// it. "0 LLM-initiated trades" is the single most-important claim on this
// site and it's literally true by architecture.

const stats = [
  { value: '0', label: 'LLM-initiated trades', note: 'the LLM explains; humans decide', kind: 'fact' },
  { value: '2', label: 'Automation tiers', note: 'SIPs + drift rebalancing — no Tier 3', kind: 'fact' },
  { value: '8', label: 'Investor safeguards', note: 'cooling-off, biometric, audit, more', kind: 'fact' },
  { value: '5s', label: 'Mandatory disclaimer', note: 'SEBI ad-code, gated in the UI', kind: 'fact' },
];
---

<section class="border-y border-slate-800 bg-slate-950 text-slate-100">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <p class="mb-8 text-center text-xs font-medium uppercase tracking-[0.32em] text-emerald-400">
      Restraint, on the record
    </p>
    <dl class="grid grid-cols-2 gap-y-10 gap-x-6 text-center sm:grid-cols-4">
      {
        stats.map((s) => (
          <div>
            <dt class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
              {s.value}
            </dt>
            <dd class="mt-2 text-sm font-medium text-slate-200">{s.label}</dd>
            <dd class="mt-1 flex items-center justify-center gap-1.5 text-xs text-slate-400">
              {s.kind === 'projection' && (
                <span class="rounded-full border border-amber-700/50 bg-amber-950/40 px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wider text-amber-300">
                  Target
                </span>
              )}
              <span>{s.note}</span>
            </dd>
          </div>
        ))
      }
    </dl>
    <p class="mt-8 text-center text-xs text-slate-500">
      Every number above is a fact about how Sthira is built, not a goal. The bar moves
      only when the architecture moves.
    </p>
  </div>
</section>
